<APPLICATION Parent="defaultwa"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:noNamespaceSchemaLocation="http://www.4js.com/ns/gas/6.00/cfextwa.xsd">
  <DESCRIPTION>
    <SHORT>Standard OS Demo</SHORT>
    <LONG>Demonstrates standard OS frontcalls: launchURL, feInfo, getEnv, openDir, openFile, openFiles, saveFile, playSound, execute, shellExec</LONG>
  </DESCRIPTION>
  <EXECUTION>
    <ENVIRONMENT_VARIABLE Id="FGLRESOURCEPATH">/Volumes/SandiskSD/bdl-frontcall/source</ENVIRONMENT_VARIABLE>
    <PATH>/Volumes/SandiskSD/bdl-frontcall/source</PATH>
    <MODULE>StandardOSDemo.42m</MODULE>
  </EXECUTION>
</APPLICATION>
